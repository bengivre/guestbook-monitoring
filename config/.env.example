# Copy to .env at the repo root and adjust.
# scripts/deploy.sh auto-loads .env if present.
# Any value can also be supplied interactively with `scripts/deploy.sh --interactive`.

# --- kind cluster ------------------------------------------------------------
CLUSTER_NAME=guestbook
KIND_WORKER_NODES=2          # number of worker nodes (control-plane is always added)

# Host ports the kind cluster maps to the pinned NodePorts below.
# Access Grafana at http://localhost:${GRAFANA_NODE_PORT} after deploy.
GRAFANA_NODE_PORT=30080
FRONTEND_NODE_PORT=30081

# --- Pulumi ------------------------------------------------------------------
PULUMI_STACK=dev
# Local (no Pulumi account) file backend by default. Point at s3://... or the
# Pulumi service (https://api.pulumi.com) instead if you prefer.
PULUMI_BACKEND_URL=file://~
# Required to encrypt secrets in the local backend.
PULUMI_CONFIG_PASSPHRASE=guestbook
# If you use the Pulumi service backend, set this instead of a passphrase:
# PULUMI_ACCESS_TOKEN=pul-xxxxxxxx

# --- Grafana -----------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=prom-operator
